PORT=8080
WORKER_TOKEN=change-this-token
PUBLIC_BASE_URL=https://domain-worker-kamu.up.railway.app

# Optional untuk YouTube yang kena bot verification.
# Jangan commit file cookies ke GitHub.
# Pilih salah satu:
#
# 1. Pakai path file cookies di server/VPS:
# YTDLP_COOKIES_PATH=/app/cookies/youtube-cookies.txt
#
# 2. Pakai base64 cookies lewat Railway Variables:
# YOUTUBE_COOKIES_B64=
