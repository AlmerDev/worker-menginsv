PORT=8080
WORKER_TOKEN=change-this-token
PUBLIC_BASE_URL=https://domain-worker-kamu.koyeb.app

# Provider utama supaya YouTube dan banyak medsos lebih mungkin jalan.
# Isi dengan Cobalt API milik kamu sendiri / instance yang kamu punya izin pakai.
COBALT_API_URL=https://cobalt-instance-kamu.example.com
COBALT_API_KEY=

# fallback yt-dlp tetap aktif
RATE_LIMIT_PER_MINUTE=20


# Optional. Isi kalau kamu punya API resolver musik tambahan.
# API ini bisa balikin { "url": "direct audio/video url" } atau { "urls": ["..."] }
MUSIC_RESOLVER_API_URL=
MUSIC_RESOLVER_API_KEY=
