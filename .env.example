PORT=8080
WORKER_TOKEN=change-this-token
PUBLIC_BASE_URL=https://domain-worker-kamu.up.railway.app

# Optional fallback kalau nanti punya provider/API sendiri.
# Harus menerima body: { url, mediaGroup, quality, fileType }
# dan return: { ok: true, downloadUrl, title }
EXTERNAL_DOWNLOADER_API_URL=
EXTERNAL_DOWNLOADER_API_KEY=

# Batas request per IP per menit
RATE_LIMIT_PER_MINUTE=20
